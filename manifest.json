{
  "manifest_version": 3,
  "name": "VCAP — QA Debug Assistant",
  "version": "0.1.0",
  "description": "Record bugs locally: video, DOM steps, API errors → .zip export. 100% local processing.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "debugger",
    "offscreen",
    "notifications",
    "tabCapture",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "VCAP: Click to start recording"
  },
  "side_panel": {
    "default_path": "src/panel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/offscreen/offscreen.html",
        "src/preview/index.html",
        "src/panel/panel.html",
        "src/popup/popup.html",
        "src/content/page-console-capture.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
